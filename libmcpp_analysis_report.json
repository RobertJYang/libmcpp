  "architecture": {
    "overview": "libmcpp 是一个现代化的C++基础库，采用分层模块化架构设计，专为高性能、可扩展的应用程序设计。核心库 mcbase 提供底层基础设施，上层模块提供应用级功能。",
    "structure": {
      "core_library": "libraries/mcbase/ - 核心基础设施库",
      "main_library": "include/mc/ + src/ - 主库API和实现",
      "tests": "tests/ - 单元测试",
      "examples": "examples/ - 示例代码"
    },
    "code_metrics": {
      "total_lines": 57359,
      "header_files": 94,
