                "--timeout=0",
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "MC_BUILD_ROOT",
                    "value": "${workspaceFolder}/builddir"
                },
                {
                    "name": "MC_GLOBAL_BUILD_ROOT",
                    "value": "${workspaceFolder}/builddir"
                },
                {
                    "name": "LD_LIBRARY_PATH",
                    "value": "${env:LD_LIBRARY_PATH}"
                },
                {
                    "name": "DYLD_LIBRARY_PATH",
                    "value": "${env:DYLD_LIBRARY_PATH}"
                }
            ],
            "externalConsole": false,
            "osx": {
                "MIMode": "lldb",
            },
